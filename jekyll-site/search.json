---
layout: null
---
[
{% assign docs = site.pages | where_exp: "p", "p.page_key" %}
{% for p in docs %}
  {
    "url": {{ p.url | jsonify }},
    "title": {{ p.title | jsonify }},
    "module": {{ p.module | default: "" | jsonify }},
    "tags": {{ p.tags | default: empty | jsonify }},
    "page_key": {{ p.page_key | jsonify }},
    "content": {{ p.content | strip_html | strip_newlines | replace: "  ", " " | replace: "   ", " " | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
