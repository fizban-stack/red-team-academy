---
import Base from '../layouts/Base.astro';
---
<Base title="About — Red Team Academy">
  <div class="home-content">
    <div class="hero">
      <div class="pre-title">// about this platform</div>
      <h1>About <span>Red Team Academy</span></h1>
      <p>
        A personal, self-hosted training platform for offensive security.
        Built to organize notes and training material across multiple lab environments
        including Game of Active Directory, Metasploitable, and other intentionally
        vulnerable systems.
      </p>
    </div>

    <h2 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--text-muted); margin-bottom:16px; font-weight:600;">
      // Lab Environments
    </h2>

    <div class="module-grid" style="margin-bottom:40px;">
      <div class="module-card">
        <div class="card-icon">GOAD</div>
        <div class="card-title">Game of Active Directory</div>
        <div class="card-desc">Multi-forest, multi-domain AD lab. Covers modern AD attack chains end-to-end.</div>
      </div>
      <div class="module-card">
        <div class="card-icon">MSF</div>
        <div class="card-title">Metasploitable</div>
        <div class="card-desc">Intentionally vulnerable Linux machine. Classic exploitation training environment.</div>
      </div>
      <div class="module-card">
        <div class="card-icon">WEB</div>
        <div class="card-title">DVWA / WebGoat</div>
        <div class="card-desc">Vulnerable web applications for OWASP Top 10 practice.</div>
      </div>
      <div class="module-card">
        <div class="card-icon">CTF</div>
        <div class="card-title">HackTheBox / THM</div>
        <div class="card-desc">Curated machines and paths on external platforms for CTF-style training.</div>
      </div>
    </div>

    <h2 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--text-muted); margin-bottom:16px; font-weight:600;">
      // How to Use
    </h2>
    <p style="color:var(--text-secondary); max-width:600px; line-height:1.8;">
      Each training page is split into two panels. The <strong style="color:var(--green-dim)">left panel</strong> is your personal notes area — notes are auto-saved to the server. The <strong style="color:var(--cyan-dim)">right panel</strong> contains structured training content, commands, and references. Use the directory tree on the left to navigate between modules.
    </p>
  </div>
</Base>
