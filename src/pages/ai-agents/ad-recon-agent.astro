@click.command()
@click.option("--objective", "-o", default="full", help="Recon objective or 'full' for complete enumeration")
@click.option("--server", "-s", required=True, help="DC IP or hostname")
@click.option("--domain", "-d", required=True, help="Domain (e.g. corp.local)")
@click.option("--model", "-m", default="qwen2.5-coder:7b")
@click.option("--ollama-url", default="http://localhost:11434")
@click.option("--output", "-O", default="report.md")
def main(objective, server, domain, model, ollama_url, output):
    """AD Recon Agent — autonomous Active Directory enumeration."""
    base_dn = "DC=" + ",DC=".join(domain.split("."))

    objectives = &#123;
        "full":      "Perform complete AD enumeration following the standard methodology",
        "quick":     "Fast enumeration: users, admins, SPNs, delegation only",
        "paths":     "Find all paths from owned users to Domain Admins via BloodHound",
        "adcs":      "Enumerate ADCS certificate templates and find ESC misconfigurations",
        "trusts":    "Enumerate all domain trusts, their direction and SID filtering status",
    &#125;

    agent = ADReconAgent(model=model, ollama_url=ollama_url)
    agent.tools.default_server = server
    agent.tools.default_base_dn = base_dn

    report = agent.run(objectives.get(objective, objective))

    with open(output, "w") as f:
        f.write(report)
    print(f"\nReport saved to: &#123;output&#125;")

if __name__ == "__main__":
    main()

