---
import Base from '../layouts/Base.astro';
---
<Base title="Red Team Academy">
  <div class="home-content">

    <div class="hero">
      <div class="pre-title">// offensive security training</div>
      <h1><span>Red Team</span> Academy</h1>
      <p>
        A structured, self-hosted training platform for offensive security.
        Work through labs, take notes, and build your red team skill set
        from fundamentals through advanced adversary simulation.
      </p>
    </div>

    <h2 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--text-muted); margin-bottom:16px; font-weight:600;">
      // Training Modules
    </h2>

    <div class="module-grid">

      <a href="/fundamentals/methodology" class="module-card">
        <div class="card-icon">🎯</div>
        <div class="card-title">Fundamentals</div>
        <div class="card-desc">Red team methodology, engagement planning, MITRE ATT&amp;CK, lab setup, Linux &amp; Windows basics, and OPSEC.</div>
        <div class="card-count">7 lessons</div>
      </a>

      <a href="/recon/passive-recon" class="module-card">
        <div class="card-icon">🔍</div>
        <div class="card-title">Reconnaissance</div>
        <div class="card-desc">OSINT, passive and active recon, subdomain enumeration, web recon, email OSINT, and infrastructure mapping.</div>
        <div class="card-count">7 lessons</div>
      </a>

      <a href="/active-directory/ad-enumeration" class="module-card">
        <div class="card-icon">🏰</div>
        <div class="card-title">Active Directory</div>
        <div class="card-desc">AD enumeration, GOAD lab, Kerberoasting, AS-REP Roasting, PTH, BloodHound, DCSync, Golden Ticket, ACL abuse.</div>
        <div class="card-count">12 lessons</div>
      </a>

      <a href="/pivoting/ssh-tunneling" class="module-card">
        <div class="card-icon">🔀</div>
        <div class="card-title">Pivoting &amp; Tunneling</div>
        <div class="card-desc">SSH tunneling, Chisel, SOCKS5, Metasploit pivoting, DNS &amp; ICMP tunneling.</div>
        <div class="card-count">6 lessons</div>
      </a>

      <a href="/evasion/amsi-bypass" class="module-card">
        <div class="card-icon">🕶️</div>
        <div class="card-title">Evasion</div>
        <div class="card-desc">AMSI bypass, AV/EDR evasion, LOLBins, fileless techniques, indirect syscalls, sleep obfuscation, stack spoofing, ETW bypass, DLL unhooking, and process ghosting.</div>
        <div class="card-count">16 lessons</div>
      </a>

      <a href="/exploitation/metasploitable" class="module-card">
        <div class="card-icon">💥</div>
        <div class="card-title">Exploitation</div>
        <div class="card-desc">Metasploitable, OWASP web attacks, service exploitation, password attacks.</div>
        <div class="card-count">5 lessons</div>
      </a>

      <a href="/post-exploitation/privesc-linux" class="module-card">
        <div class="card-icon">🐚</div>
        <div class="card-title">Post-Exploitation</div>
        <div class="card-desc">Privilege escalation, lateral movement, persistence, and data exfiltration.</div>
        <div class="card-count">5 lessons</div>
      </a>

      <a href="/c2-frameworks/metasploit" class="module-card">
        <div class="card-icon">🎛️</div>
        <div class="card-title">C2 Frameworks</div>
        <div class="card-desc">Metasploit, Cobalt Strike, Sliver, Havoc, Brute Ratel, BOFs, malleable profiles, redirectors, and C2 OPSEC.</div>
        <div class="card-count">10 lessons</div>
      </a>

      <a href="/web/sql-injection" class="module-card">
        <div class="card-icon">🌐</div>
        <div class="card-title">Web Hacking</div>
        <div class="card-desc">Advanced SQLi, XSS/CSP bypass, SSRF, JWT attacks, GraphQL, HTTP smuggling, OAuth, XXE, prototype pollution, and API testing.</div>
        <div class="card-count">11 lessons</div>
      </a>

      <a href="/iot/firmware-extraction" class="module-card">
        <div class="card-icon">📡</div>
        <div class="card-title">IoT Hacking</div>
        <div class="card-desc">Firmware extraction, hardware hacking (UART/JTAG), MQTT/CoAP attacks, BLE/RF, router exploitation, and industrial protocols.</div>
        <div class="card-count">8 lessons</div>
      </a>

      <a href="/reporting/findings" class="module-card">
        <div class="card-icon">📋</div>
        <div class="card-title">Reporting</div>
        <div class="card-desc">Documenting findings, writing executive and technical reports.</div>
        <div class="card-count">3 lessons</div>
      </a>

    </div>
  </div>
</Base>
