# RevShell API configuration. Copy to .env and edit, or export inline.
# All values are optional — defaults apply when unset.

# ─── Network ────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8080

# ─── Auth (HIGHLY recommended in shared labs) ───────────────────────────────
# Generate: openssl rand -hex 32
API_TOKEN=

# ─── Audit log ──────────────────────────────────────────────────────────────
# When set, every generated payload is recorded as a JSONL row.
# Use with X-Engagement-ID header to tag by engagement.
AUDIT_LOG=

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated origins. Defaults to localhost only.
CORS_ORIGINS=http://localhost,http://localhost:8080,http://127.0.0.1:8080

# ─── Rate limits (slowapi syntax) ───────────────────────────────────────────
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_GENERATE=60/minute

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
